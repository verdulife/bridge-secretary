{
  "name": "bridge",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun scripts/start.ts",
    "dev": "bun --watch src/index.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:8520",
    "bridge": "concurrently \"bun tunnel\" \"bun dev\""
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "concurrently": "^9.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "groq-sdk": "^0.37.0",
    "telegraf": "^4.16.3"
  }
}