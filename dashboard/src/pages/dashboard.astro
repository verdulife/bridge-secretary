---
import { turso } from "../lib/turso";

const chatId = Astro.url.searchParams.get("chatId");

if (!chatId) {
  return Astro.redirect("/");
}

// Fetch user data from Turso
const result = await turso.execute({
  sql: "SELECT * FROM users WHERE id = ?",
  args: [chatId],
});

const user = result.rows[0];

if (!user) {
  // If user doesn't exist, we could create them or redirect
  // For now, redirect to index
  return Astro.redirect("/");
}

const notionConnected = !!user.notion_token;
const googleConnected = !!user.google_token;
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Dashboard | Bridge</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&display=swap');
        
        :root {
            --bg: #0a0a0c;
            --accent: #6366f1;
            --text: #f8fafc;
            --card-glass: rgba(255, 255, 255, 0.03);
            --card-border: rgba(255, 255, 255, 0.1);
            --success: #10b981;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            min-height: 100vh;
            background: radial-gradient(circle at 0% 0%, #1e1e2e 0%, #0a0a0c 50%);
            display: flex;
            justify-content: center;
            padding-top: 5vh;
        }

        .dashboard {
            max-width: 600px;
            width: 90%;
            animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .card {
            backdrop-filter: blur(16px);
            background: var(--card-glass);
            border: 1px solid var(--card-border);
            border-radius: 1.5rem;
            padding: 2rem;
            margin-bottom: 2rem;
        }

        h2 {
            margin-top: 0;
            font-weight: 600;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        label {
            display: block;
            margin-bottom: 0.5rem;
            color: #94a3b8;
            font-size: 0.9rem;
        }

        input {
            width: 100%;
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--card-border);
            border-radius: 0.75rem;
            padding: 0.8rem 1rem;
            color: white;
            font-family: inherit;
            box-sizing: border-box;
            transition: border-color 0.2s;
        }

        input:focus {
            outline: none;
            border-color: var(--accent);
        }

        .services {
            display: grid;
            gap: 1rem;
        }

        .service-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.25rem;
            background: rgba(255,255,255,0.02);
            border-radius: 1rem;
            border: 1px solid var(--card-border);
        }

        .status-tag {
            font-size: 0.75rem;
            padding: 0.25rem 0.6rem;
            border-radius: 2rem;
            font-weight: 600;
            text-transform: uppercase;
        }

        .status-connected { background: rgba(16, 185, 129, 0.1); color: var(--success); }
        .status-pending { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }

        .btn {
            padding: 0.6rem 1.2rem;
            border-radius: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            border: none;
        }

        .btn-primary { background: var(--accent); color: white; }
        .btn-secondary { background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--card-border); }

        .btn:hover { filter: brightness(1.2); transform: translateY(-1px); }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        header {
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .user-badge {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--card-glass);
            padding: 0.4rem 1rem;
            border-radius: 2rem;
            font-size: 0.9rem;
            border: 1px solid var(--card-border);
        }
    </style>
</head>
<body>
    <div class="dashboard">
        <header>
            <h1 style="margin:0; font-size: 1.8rem; letter-spacing: -1px;">Bridge <span style="color: var(--accent);">.</span></h1>
            <div class="user-badge">
                <span style="opacity: 0.5;">ID:</span> {chatId}
            </div>
        </header>

        <div class="card">
            <h2>⚙️ Configuración Personal</h2>
            <form action="/api/save-settings" method="POST">
                <input type="hidden" name="chatId" value={chatId} />
                <div class="form-group">
                    <label>Nombre de Usuario (Cómo te llamo)</label>
                    <input type="text" name="first_name" value={user.first_name} placeholder="Ej: Juan" />
                </div>
                <div style="text-align: right;">
                    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                </div>
            </form>
        </div>

        <div class="card">
            <h2>🔗 Vinculaciones</h2>
            <div class="services">
                <div class="service-item">
                    <div>
                        <div style="font-weight: 600;">Notion</div>
                        <div style="font-size: 0.8rem; color: #94a3b8;">Gestión de tareas y notas</div>
                    </div>
                    {notionConnected ? (
                        <span class="status-tag status-connected">Conectado</span>
                    ) : (
                        <a href={`/api/auth/notion?chatId=${chatId}`} class="btn btn-secondary">Conectar</a>
                    )}
                </div>

                <div class="service-item">
                    <div>
                        <div style="font-weight: 600;">Gmail</div>
                        <div style="font-size: 0.8rem; color: #94a3b8;">Lectura y resumen de correos</div>
                    </div>
                    {googleConnected ? (
                        <span class="status-tag status-connected">Conectado</span>
                    ) : (
                        <a href={`/api/auth/google?chatId=${chatId}`} class="btn btn-secondary">Conectar</a>
                    )}
                </div>

                <div class="service-item">
                    <div>
                        <div style="font-weight: 600;">Google Calendar</div>
                        <div style="font-size: 0.8rem; color: #94a3b8;">Gestión de agenda y eventos</div>
                    </div>
                    {googleConnected ? (
                        <span class="status-tag status-connected">Conectado</span>
                    ) : (
                        <a href={`/api/auth/google?chatId=${chatId}`} class="btn btn-secondary">Conectar</a>
                    )}
                </div>
            </div>
        </div>
        
        <p style="text-align: center; color: #475569; font-size: 0.8rem;">
            Tus datos están protegidos y sólo Bridge tiene acceso a ellos.
        </p>
    </div>
</body>
</html>
